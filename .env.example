PORT=8787
DATABASE_URL=postgresql://user:pass@host:5432/dbname
JWT_SECRET=<随机长字符串>

# 管理后台：可注册为管理员的邮箱（逗号分隔）
ADMIN_EMAILS=admin@example.com

# 上传目录与大小限制
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

# 简历解析（可选）：用户无 License 时使用 MODEL_API_KEY 作为备用
# MODEL_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# MODEL_API_KEY=<api_key>

# AI 代理：客户端通过 x-license-key 提供上游 API Key，服务端无需配置 AI_API_KEY
# AI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_ASR_API_BASE=https://dashscope.aliyuncs.com/api/v1
